generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CASHIER)
  restaurantId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isActive     Boolean  @default(true)

  auditLogs        AuditLog[]
  ownedRestaurants Restaurant[] @relation("RestaurantOwner")
  sessions         Session[]
  shifts           Shift[]
  attendances      Attendance[]

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  taxRate     Int      @default(0)
  serviceRate Int      @default(0)
  logoUrl     String?
  ownerId     String
  createdAt   DateTime @default(now())

  autoPrint     Boolean @default(false)
  currency      String  @default("IDR")
  orderPrefix   String  @default("ORD")
  receiptFooter String? @default("Thank you for your order.")
  timezone      String  @default("Asia/Jakarta")

  cardEnabled       Boolean @default(false)
  cashEnabled       Boolean @default(true)
  midtransEnabled   Boolean @default(false)
  qrisEnabled       Boolean @default(false)
  transferEnabled   Boolean @default(false)
  midtransServerKey String?
  midtransClientKey String?

  auditLog          AuditLog[]
  categories        Category[]
  tables            DiningTable[]
  orders            Order[]
  menuItems         MenuItem[]
  inventoryItems    InventoryItem[]
  shifts            Shift[]
  employees         User[]
  attendances       Attendance[]
  attendanceSetting AttendanceSetting?

  owner User @relation("RestaurantOwner", fields: [ownerId], references: [id])
}

model Category {
  id           String   @id @default(cuid())
  name         String
  restaurantId String?
  createdAt    DateTime @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@unique([name, restaurantId])
}

model MenuItem {
  id           String   @id @default(cuid())
  name         String
  price        Int
  imageUrl     String?
  restaurantId String
  categoryId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  description  String?
  isAvailable  Boolean  @default(true)

  orderItems OrderItem[]
  recipes    Recipe[]

  category   Category?  @relation(fields: [categoryId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
}

model InventoryItem {
  id   String  @id @default(cuid())
  name String
  sku  String?

  type InventoryType
  unit InventoryUnit

  currentStock Float @default(0)
  minimumStock Float @default(0)

  costPerUnit Int @default(0)

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  movements StockMovement[]
  recipes   Recipe[]

  @@unique([restaurantId, name])

  @@index([restaurantId])
  @@index([currentStock])
  @@index([minimumStock])
}

model Recipe {
  id              String @id @default(cuid())
  menuItemId      String
  inventoryItemId String
  quantityNeeded  Float

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, inventoryItemId])
}

model Order {
  id          String @id @default(cuid())
  orderNumber Int

  subtotal      Int
  taxAmount     Int
  serviceAmount Int
  total         Int

  paymentMethod String
  amountPaid    Int
  changeAmount  Int

  status OrderStatus @default(PENDING_PAYMENT)

  inventoryDeducted Boolean @default(false)

  restaurantId String
  shiftId      String?
  tableId      String?

  type OrderType @default(TAKEAWAY)

  cancelReason String?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shift      Shift?       @relation(fields: [shiftId], references: [id])
  table      DiningTable? @relation(fields: [tableId], references: [id])

  items   OrderItem[]
  payment Payment?

  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique

  provider String
  method   String
  status   PaymentStatus @default(PENDING)

  externalId String?
  paymentUrl String?
  qrString   String?
  vaNumber   String?
  paidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([method])
  @@index([provider])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String

  quantity Int
  price    Int
  subtotal Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model StockMovement {
  id              String @id @default(cuid())
  inventoryItemId String

  type     StockMovementType
  quantity Float
  note     String?
  reason   StockMovementReason?

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([reason])
  @@index([createdAt])
  @@index([type])
}

model DiningTable {
  id           String      @id @default(cuid())
  name         String
  capacity     Int         @default(2)
  status       TableStatus @default(AVAILABLE)
  isActive     Boolean     @default(true)
  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]
}

model Shift {
  id           String @id @default(cuid())
  userId       String
  restaurantId String

  status ShiftStatus @default(OPEN)

  openingCash    Int  @default(0)
  closingCash    Int?
  expectedCash   Int  @default(0)
  cashDifference Int?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  orders Order[]

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([restaurantId])
  @@index([status])
  @@index([openedAt])
}

model Attendance {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  clockInAt  DateTime
  clockOutAt DateTime?

  workDurationMinutes Int @default(0)
  overtimeMinutes     Int @default(0)

  note String?

  status AttendanceStatus @default(PRESENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
}

model AttendanceSetting {
  id           String @id @default(cuid())
  restaurantId String @unique

  workStartHour   Int @default(9)
  workStartMinute Int @default(0)
  lateTolerance   Int @default(15)

  overtimeAfterMinutes Int @default(480)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId], name: "role_permissionId")
}

model AuditLog {
  id           String @id @default(cuid())
  restaurantId String
  userId       String

  action     AuditAction
  entityType String
  entityId   String
  changes    Json?

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  SERVER
}

enum InventoryType {
  INGREDIENT
  PACKAGING
  EQUIPMENT
}

enum InventoryUnit {
  PCS
  GRAM
  KILOGRAM
  LITER
  ML
  PACK
  BOTTLE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  INACTIVE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum StockMovementReason {
  PURCHASE
  RECIPE_USAGE
  WASTE
  EXPIRED
  MANUAL_ADJUSTMENT
  DAMAGED
}
