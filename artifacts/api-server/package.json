{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "generate": "prisma generate",
    "build": "pnpm run generate && node ./build.mjs",
    "start": "node --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "pnpm run generate && tsc -p tsconfig.json --noEmit",
    "typecheck:restaurant": "pnpm run restaurant:schema:verify && pnpm run generate && tsc -p tsconfig.restaurant.json --noEmit",
    "typecheck:retail": "pnpm run generate && tsc -p tsconfig.retail.json --noEmit",
    "typecheck:raw-material": "pnpm run generate && tsc -p tsconfig.raw-material.json --noEmit",
    "restaurant:schema:verify": "node ./scripts/verify-restaurant-prisma-schema.mjs",
    "restaurant:roles:normalize": "tsx ./scripts/normalize-legacy-user-roles.ts",
    "restaurant:seed": "tsx ./scripts/ensure-restaurant-profile-compatible.ts && tsx ./scripts/seed-restaurant-demo-data.ts",
    "retail:db:apply": "node ./scripts/apply-retail-db.mjs",
    "retail:seed": "tsx ./scripts/seed-retail-demo-data.ts",
    "retail:schema:sync": "tsx ./scripts/sync-retail-return-prisma-schema.ts",
    "raw-material:db:apply": "node ./scripts/apply-raw-material-db.mjs",
    "raw-material:policy:check": "tsx ./scripts/check-raw-material-policy.ts",
    "raw-material:seed": "tsx ./scripts/seed-raw-material-demo-data.ts",
    "service:db:apply": "node ./scripts/apply-service-business-db.mjs",
    "service:seed": "tsx ./scripts/seed-service-business-demo-data.ts",
    "backfill:businesses": "node --env-file-if-exists=.env --import tsx ./scripts/backfill-business-tenant-bridge.ts",
    "backfill:inventory-business-scope": "node --env-file-if-exists=.env --import tsx ./scripts/backfill-inventory-business-scope.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
