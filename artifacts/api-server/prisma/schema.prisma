generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CASHIER)
  restaurantId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isActive     Boolean  @default(true)

  auditLogs        AuditLog[]
  ownedRestaurants Restaurant[]    @relation("RestaurantOwner")
  ownedBusinesses  Business[]      @relation("BusinessOwner")
  sessions         Session[]
  shifts           Shift[]
  attendances      Attendance[]
  stockMovements   StockMovement[] @relation("StockMovementActor")

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id   String       @id @default(cuid())
  name String
  type BusinessType @default(RESTAURANT)
  mode BusinessMode @default(RESTAURANT)

  ownerId  String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner          User            @relation("BusinessOwner", fields: [ownerId], references: [id])
  restaurant     Restaurant?
  inventoryItems InventoryItem[] @relation("BusinessInventoryItems")
  stockMovements StockMovement[] @relation("BusinessStockMovements")

  @@index([ownerId])
  @@index([type])
  @@index([mode])
  @@index([isActive])
}

model Restaurant {
  id         String  @id @default(cuid())
  businessId String? @unique

  name        String
  address     String?
  phone       String?
  taxRate     Int      @default(0)
  serviceRate Int      @default(0)
  logoUrl     String?
  ownerId     String
  createdAt   DateTime @default(now())

  autoPrint     Boolean @default(false)
  currency      String  @default("IDR")
  orderPrefix   String  @default("ORD")
  receiptFooter String? @default("Thank you for your order.")
  timezone      String  @default("Asia/Jakarta")

  cardEnabled       Boolean @default(false)
  cashEnabled       Boolean @default(true)
  midtransEnabled   Boolean @default(false)
  qrisEnabled       Boolean @default(false)
  transferEnabled   Boolean @default(false)
  midtransServerKey String?
  midtransClientKey String?

  auditLog          AuditLog[]
  categories        Category[]
  tables            DiningTable[]
  orders            Order[]
  invoices          Invoice[]
  menuItems         MenuItem[]
  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[] @relation("RestaurantStockMovements")
  shifts            Shift[]
  employees         User[]
  attendances       Attendance[]
  attendanceSetting AttendanceSetting?

  owner    User      @relation("RestaurantOwner", fields: [ownerId], references: [id])
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
}

model Category {
  id           String   @id @default(cuid())
  name         String
  restaurantId String?
  createdAt    DateTime @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@unique([name, restaurantId])
}

model MenuItem {
  id           String   @id @default(cuid())
  name         String
  price        Int
  imageUrl     String?
  restaurantId String
  categoryId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  description  String?
  isAvailable  Boolean  @default(true)

  orderItems OrderItem[]
  recipes    Recipe[]

  category   Category?  @relation(fields: [categoryId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
}

model InventoryItem {
  id   String  @id @default(cuid())
  name String
  sku  String?

  type InventoryType
  unit InventoryUnit

  currentStock Float @default(0)
  minimumStock Float @default(0)

  costPerUnit Int @default(0)

  /// New shared-business scope. Optional during the Restaurant bridge phase.
  businessId String?

  /// Legacy Restaurant scope. Keep this required until menu/recipe/order flows are migrated.
  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business?  @relation("BusinessInventoryItems", fields: [businessId], references: [id], onDelete: SetNull)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  movements StockMovement[]
  recipes   Recipe[]

  @@unique([restaurantId, name])
  @@unique([businessId, name])
  @@index([businessId])
  @@index([restaurantId])
  @@index([sku])
  @@index([type])
  @@index([currentStock])
  @@index([minimumStock])
}

model Recipe {
  id              String @id @default(cuid())
  menuItemId      String
  inventoryItemId String
  quantityNeeded  Float

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, inventoryItemId])
}

model Order {
  id          String @id @default(cuid())
  orderNumber Int

  subtotal      Int
  taxAmount     Int
  serviceAmount Int
  total         Int

  paymentMethod String
  amountPaid    Int
  changeAmount  Int

  status OrderStatus @default(PENDING_PAYMENT)

  inventoryDeducted Boolean @default(false)

  restaurantId String
  shiftId      String?
  tableId      String?

  type OrderType @default(TAKEAWAY)

  cancelReason String?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shift      Shift?       @relation(fields: [shiftId], references: [id])
  table      DiningTable? @relation(fields: [tableId], references: [id])

  items   OrderItem[]
  payment Payment?

  // Bug #4 fix: enforce uniqueness at the DB level so concurrent transactions
  // that compute the same orderNumber produce a P2002 (caught + retried in the
  // route) instead of silently writing duplicate order numbers.
  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique

  provider String
  method   String
  status   PaymentStatus @default(PENDING)

  externalId String?
  paymentUrl String?
  qrString   String?
  vaNumber   String?
  paidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([method])
  @@index([provider])
}

model Invoice {
  id String @id @default(cuid())

  restaurantId String

  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)

  businessName    String
  businessEmail   String?
  businessPhone   String?
  businessAddress String?

  customerName    String
  customerPhone   String?
  customerAddress String?

  notes String?

  discountType   InvoiceDiscountType @default(PERCENTAGE)
  discountValue  Float               @default(0)
  subtotal       Int                 @default(0)
  discountAmount Int                 @default(0)
  grandTotal     Int                 @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cancelledAt DateTime?

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      InvoiceItem[]

  @@unique([restaurantId, invoiceNumber])
  @@index([restaurantId])
  @@index([status])
  @@index([invoiceDate])
  @@index([createdAt])
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String

  description String
  quantity    Float
  unitPrice   Int
  lineTotal   Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String

  quantity Int
  price    Int
  subtotal Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model StockMovement {
  id              String @id @default(cuid())
  inventoryItemId String

  /// New shared-business scope. Optional until backfill is complete.
  businessId String?

  /// Legacy Restaurant scope copied onto movement for faster filtering and reporting.
  restaurantId String?

  /// User who caused the movement. Optional while old rows/backfills exist.
  actorId String?

  type     StockMovementType
  quantity Float

  previousStock Float?
  newStock      Float?

  unitCostSnapshot Int?

  sourceType StockMovementSource?
  sourceId   String?

  note   String?
  reason StockMovementReason?

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  business      Business?     @relation("BusinessStockMovements", fields: [businessId], references: [id], onDelete: SetNull)
  restaurant    Restaurant?   @relation("RestaurantStockMovements", fields: [restaurantId], references: [id], onDelete: SetNull)
  actor         User?         @relation("StockMovementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([restaurantId])
  @@index([inventoryItemId])
  @@index([actorId])
  @@index([sourceType])
  @@index([sourceId])
  @@index([reason])
  @@index([createdAt])
  @@index([type])
}

model DiningTable {
  id           String      @id @default(cuid())
  name         String
  capacity     Int         @default(2)
  status       TableStatus @default(AVAILABLE)
  isActive     Boolean     @default(true)
  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]
}

model Shift {
  id           String @id @default(cuid())
  userId       String
  restaurantId String

  status ShiftStatus @default(OPEN)

  openingCash    Int  @default(0)
  closingCash    Int?
  expectedCash   Int  @default(0)
  cashDifference Int?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  orders Order[]

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([restaurantId])
  @@index([status])
  @@index([openedAt])
}

model Attendance {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  clockInAt  DateTime
  clockOutAt DateTime?

  workDurationMinutes Int @default(0)
  overtimeMinutes     Int @default(0)

  note String?

  status AttendanceStatus @default(PRESENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
}

model AttendanceSetting {
  id           String @id @default(cuid())
  restaurantId String @unique

  workStartHour   Int @default(9)
  workStartMinute Int @default(0)
  lateTolerance   Int @default(15)

  overtimeAfterMinutes Int @default(480)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId], name: "role_permissionId")
}

model AuditLog {
  id           String @id @default(cuid())
  restaurantId String
  userId       String

  action     AuditAction
  entityType String
  entityId   String
  changes    Json?

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  SERVER
}

enum InventoryType {
  INGREDIENT
  PACKAGING
  EQUIPMENT

  // Shared / Retail-ready
  PRODUCT
  RAW_MATERIAL
  FINISHED_GOOD

  // Service-ready
  SUPPLY
  TOOL
  SPARE_PART

  // Livestock-ready
  FEED
  MEDICINE
}

enum InventoryUnit {
  PCS
  GRAM
  KILOGRAM
  LITER
  ML
  PACK
  BOTTLE

  // Shared / retail / livestock-ready
  BOX
  CARTON
  SACK
  ROLL
  SET
  PAIR
  DOSE
  TABLET
  CAPSULE
  VIAL
  CAN
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum InvoiceDiscountType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  INACTIVE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum StockMovementReason {
  PURCHASE
  RECIPE_USAGE
  WASTE
  EXPIRED
  MANUAL_ADJUSTMENT
  DAMAGED
  RETURN

  // Shared / future-ready reasons
  OPENING_STOCK
  STOCK_COUNT
  CORRECTION
  TRANSFER_IN
  TRANSFER_OUT
  PRODUCTION_USAGE
  SERVICE_USAGE
  LIVESTOCK_USAGE
  IMPORT
}

enum StockMovementSource {
  MANUAL
  ORDER
  RECIPE
  PURCHASE
  WASTE
  RETURN
  TRANSFER
  STOCK_COUNT
  IMPORT
  SYSTEM
}

enum BusinessType {
  RESTAURANT
  RETAIL
  SERVICE
  LIVESTOCK
}

enum BusinessMode {
  RESTAURANT
  RETAIL
  SERVICE
  LIVESTOCK
}
