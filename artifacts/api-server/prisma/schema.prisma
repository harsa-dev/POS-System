generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  businessId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isActive     Boolean  @default(true)

  business                  Business?                  @relation("BusinessEmployees", fields: [businessId], references: [id])
  ownedBusinesses           Business[]                 @relation("BusinessOwner")
  sessions                  Session[]
  shifts                    Shift[]
  attendances               Attendance[]
  auditLogs                 AuditLog[]
  stockMovements            StockMovement[]            @relation("StockMovementActor")
  rawMaterialStockMovements RawMaterialStockMovement[] @relation("RawMaterialStockMovementActor")
  cashflowEntries           CashflowEntry[]            @relation("CashflowEntryCreator")
  retailSales              RetailSale[]              @relation("RetailSaleCreator")
  retailStockMovements     RetailStockMovement[]     @relation("RetailStockMovementActor")
  retailReturns            RetailReturn[]            @relation("RetailReturnCreator")



  @@index([businessId])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id        String       @id @default(cuid())
  name      String
  type      BusinessType @default(RESTAURANT)
  mode      BusinessMode @default(RESTAURANT)
  ownerId   String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  owner                       User                         @relation("BusinessOwner", fields: [ownerId], references: [id])
  employees                   User[]                       @relation("BusinessEmployees")
  restaurant                  Restaurant?
  categories                  Category[]
  menuItems                   MenuItem[]
  inventoryItems              InventoryItem[]              @relation("BusinessInventoryItems")
  orders                      Order[]
  invoices                    Invoice[]
  stockMovements              StockMovement[]              @relation("BusinessStockMovements")
  cashflowEntries             CashflowEntry[]              @relation("BusinessCashflowEntries")
  serviceRequests             ServiceRequest[]
  rawMaterialSuppliers        RawMaterialSupplier[]
  rawMaterialStorageLocations RawMaterialStorageLocation[]
  rawMaterialIntakes          RawMaterialIntake[]
  rawMaterialWeighings        RawMaterialWeighing[]
  rawMaterialBatches          RawMaterialBatch[]
  rawMaterialProcessingRuns   RawMaterialProcessingRun[]
  rawMaterialKandangPens      RawMaterialKandangPen[]
  rawMaterialStockMovements   RawMaterialStockMovement[]
  tables                      DiningTable[]
  shifts                      Shift[]
  attendances                 Attendance[]
  attendanceSetting           AttendanceSetting?
  auditLogs                   AuditLog[]
  retailSuppliers             RetailSupplier[]
  retailProducts              RetailProduct[]
  retailReceivings            RetailReceiving[]
  retailSales                 RetailSale[]
  retailStockMovements        RetailStockMovement[]
  retailReturns               RetailReturn[]
  hppBatches                  HppBatch[]



  @@index([ownerId])
  @@index([type])
  @@index([mode])
  @@index([isActive])
}

model Restaurant {
  id                String   @id @default(cuid())
  businessId        String   @unique
  address           String?
  phone             String?
  taxRate           Int      @default(0)
  serviceRate       Int      @default(0)
  logoUrl           String?
  autoPrint         Boolean  @default(false)
  currency          String   @default("IDR")
  orderPrefix       String   @default("ORD")
  receiptFooter     String?  @default("Thank you for your order.")
  timezone          String   @default("Asia/Jakarta")
  cardEnabled       Boolean  @default(false)
  cashEnabled       Boolean  @default(true)
  midtransEnabled   Boolean  @default(false)
  qrisEnabled       Boolean  @default(false)
  transferEnabled   Boolean  @default(false)
  midtransServerKey String?
  midtransClientKey String?
  createdAt         DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Category {
  id         String   @id @default(cuid())
  name       String
  businessId String
  createdAt  DateTime @default(now())

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@unique([businessId, name])
  @@index([businessId])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Int
  imageUrl    String?
  businessId  String
  categoryId  String?
  description String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  recipes    Recipe[]

  @@index([businessId])
  @@index([categoryId])
  @@index([isAvailable])
}

model InventoryItem {
  id           String        @id @default(cuid())
  name         String
  sku          String?
  type         InventoryType
  unit         InventoryUnit
  currentStock Float         @default(0)
  minimumStock Float         @default(0)
  costPerUnit  Int           @default(0)
  businessId   String
  /// Legacy compatibility while old restaurant-scoped services migrate to businessId.
  restaurantId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  business  Business        @relation("BusinessInventoryItems", fields: [businessId], references: [id], onDelete: Cascade)
  movements StockMovement[]
  recipes   Recipe[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([restaurantId])
  @@index([sku])
  @@index([type])
  @@index([currentStock])
  @@index([minimumStock])
}

model Recipe {
  id              String @id @default(cuid())
  menuItemId      String
  inventoryItemId String
  quantityNeeded  Float

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, inventoryItemId])
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       Int
  subtotal          Int
  taxAmount         Int
  serviceAmount     Int
  total             Int
  paymentMethod     String
  amountPaid        Int
  changeAmount      Int
  status            OrderStatus @default(PENDING_PAYMENT)
  inventoryDeducted Boolean     @default(false)
  businessId        String
  shiftId           String?
  tableId           String?
  type              OrderType   @default(TAKEAWAY)
  cancelReason      String?
  cancelledAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  shift    Shift?       @relation(fields: [shiftId], references: [id])
  table    DiningTable? @relation(fields: [tableId], references: [id])
  items    OrderItem[]
  payment  Payment?

  @@unique([businessId, orderNumber])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
}

model Payment {
  id         String        @id @default(cuid())
  orderId    String        @unique
  provider   String
  method     String
  status     PaymentStatus @default(PENDING)
  externalId String?
  paymentUrl String?
  qrString   String?
  vaNumber   String?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([method])
  @@index([provider])
}

model Invoice {
  id              String              @id @default(cuid())
  businessId      String
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime?
  status          InvoiceStatus       @default(DRAFT)
  businessName    String
  businessEmail   String?
  businessPhone   String?
  businessAddress String?
  customerName    String
  customerPhone   String?
  customerAddress String?
  notes           String?
  discountType    InvoiceDiscountType @default(PERCENTAGE)
  discountValue   Float               @default(0)
  subtotal        Int                 @default(0)
  discountAmount  Int                 @default(0)
  grandTotal      Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  cancelledAt     DateTime?

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([status])
  @@index([invoiceDate])
  @@index([createdAt])
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Int
  lineTotal   Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Int
  subtotal   Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model RetailSupplier {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  leadTimeDays     Int      @default(0)
  reliabilityScore Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products   RetailProduct[]
  receivings RetailReceiving[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([isActive])
}

model RetailProduct {
  id             String   @id @default(cuid())
  businessId     String
  supplierId     String?
  sku            String
  barcode        String
  name           String
  brand          String   @default("")
  category       String   @default("general")
  unit           String   @default("pcs")
  price          Int      @default(0)
  cost           Int      @default(0)
  taxRatePercent Int      @default(0)
  currentStock   Int      @default(0)
  reorderPoint   Int      @default(0)
  shelfLocation  String   @default("")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business       Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier       RetailSupplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  receivingItems RetailReceivingItem[]
  saleItems      RetailSaleItem[]
  stockMovements RetailStockMovement[]
  returnItems    RetailReturnItem[]


  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId])
  @@index([supplierId])
  @@index([category])
  @@index([currentStock])
  @@index([reorderPoint])
  @@index([isActive])
}

model RetailReceiving {
  id              String   @id @default(cuid())
  businessId      String
  supplierId      String
  referenceNumber String
  status          String   @default("ordered")
  expectedDate    DateTime
  receivedAt      DateTime?
  totalCost       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier RetailSupplier        @relation(fields: [supplierId], references: [id])
  items    RetailReceivingItem[]

  @@unique([businessId, referenceNumber])
  @@index([businessId])
  @@index([supplierId])
  @@index([status])
  @@index([expectedDate])
}

model RetailReceivingItem {
  id          String @id @default(cuid())
  receivingId String
  productId   String
  orderedQty  Int    @default(0)
  receivedQty Int    @default(0)
  unitCost    Int    @default(0)

  receiving RetailReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  product   RetailProduct   @relation(fields: [productId], references: [id])

  @@index([receivingId])
  @@index([productId])
}

model RetailSale {
  id            String   @id @default(cuid())
  businessId    String
  createdById   String
  receiptNumber String
  paymentMethod String
  subtotal      Int      @default(0)
  discountTotal Int      @default(0)
  taxIncluded   Int      @default(0)
  total         Int      @default(0)
  grossProfit   Int      @default(0)
  status        String   @default("completed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business  Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User             @relation("RetailSaleCreator", fields: [createdById], references: [id])
  items     RetailSaleItem[]
  payment   RetailPayment?
  returns   RetailReturn[]


  @@unique([businessId, receiptNumber])
  @@index([businessId])
  @@index([createdById])
  @@index([paymentMethod])
  @@index([status])
  @@index([createdAt])
}

model RetailSaleItem {
  id             String @id @default(cuid())
  saleId         String
  productId      String
  skuSnapshot    String
  nameSnapshot   String
  quantity       Int
  unitPrice      Int
  costSnapshot   Int
  subtotal       Int
  discountAmount Int    @default(0)
  taxIncluded    Int    @default(0)
  lineTotal      Int
  grossProfit    Int    @default(0)

  sale    RetailSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product RetailProduct @relation(fields: [productId], references: [id])
  returnItems RetailReturnItem[]


  @@index([saleId])
  @@index([productId])
}

model RetailPayment {
  id        String   @id @default(cuid())
  saleId    String   @unique
  provider  String   @default("manual")
  method    String
  status    String   @default("paid")
  amount    Int      @default(0)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale RetailSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([method])
  @@index([status])
}

model RetailReturn {
  id                    String   @id @default(cuid())
  businessId            String
  saleId                String
  createdById           String
  returnNumber          String
  originalReceiptNumber String
  reason                String
  status                String   @default("completed")
  refundAmount          Int      @default(0)
  restockedQuantity     Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business  Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale      RetailSale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy User               @relation("RetailReturnCreator", fields: [createdById], references: [id])
  items     RetailReturnItem[]

  @@unique([businessId, returnNumber])
  @@index([businessId])
  @@index([saleId])
  @@index([createdById])
  @@index([reason])
  @@index([status])
  @@index([createdAt])
}

model RetailReturnItem {
  id                String   @id @default(cuid())
  returnId          String
  saleItemId        String
  productId         String
  skuSnapshot       String
  nameSnapshot      String
  quantity          Int
  unitPrice         Int
  refundAmount      Int      @default(0)
  restockable       Boolean  @default(false)
  restockedQuantity Int      @default(0)
  createdAt         DateTime @default(now())

  return  RetailReturn   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem RetailSaleItem @relation(fields: [saleItemId], references: [id])
  product  RetailProduct  @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
  @@index([restockable])
}

model RetailStockMovement {
  id             String   @id @default(cuid())
  businessId     String
  productId      String
  type           String
  reason         String
  source         String
  sourceId       String?
  quantity       Int
  beforeQuantity Int
  afterQuantity  Int
  note           String?
  createdById    String?
  createdAt      DateTime @default(now())

  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product   RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("RetailStockMovementActor", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([productId])
  @@index([type])
  @@index([reason])
  @@index([source])
  @@index([createdAt])
}

model RawMaterialSupplier {
  id               String                      @id @default(cuid())
  businessId       String
  name             String
  contactPerson    String?
  phone            String?
  email            String?
  address          String?
  category         RawMaterialSupplierCategory @default(RAW_GOODS)
  reliabilityScore Int                         @default(0)
  leadTimeDays     Int                         @default(0)
  isActive         Boolean                     @default(true)
  notes            String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  intakes  RawMaterialIntake[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([category])
  @@index([isActive])
  @@index([reliabilityScore])
}

model RawMaterialStorageLocation {
  id                 String                 @id @default(cuid())
  businessId         String
  code               String
  name               String
  type               RawMaterialStorageType @default(DRY)
  capacityKg         Float                  @default(0)
  usedKg             Float                  @default(0)
  temperatureCelsius Float?
  isActive           Boolean                @default(true)
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  business             Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  intakes              RawMaterialIntake[]
  batches              RawMaterialBatch[]
  sourceStockMovements RawMaterialStockMovement[] @relation("RawMaterialStockMovementSourceStorage")
  targetStockMovements RawMaterialStockMovement[] @relation("RawMaterialStockMovementTargetStorage")

  @@unique([businessId, code])
  @@index([businessId])
  @@index([type])
  @@index([isActive])
  @@index([usedKg])
  @@index([capacityKg])
}

model RawMaterialIntake {
  id                      String                  @id @default(cuid())
  businessId              String
  referenceNumber         String
  supplierId              String
  targetStorageLocationId String
  materialName            String
  unit                    RawMaterialUnit         @default(KG)
  receivedQuantity        Float
  acceptedQuantity        Float                   @default(0)
  rejectedQuantity        Float                   @default(0)
  qualityStatus           RawMaterialIntakeStatus @default(INSPECTION)
  receivedAt              DateTime                @default(now())
  notes                   String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  business              Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier              RawMaterialSupplier        @relation(fields: [supplierId], references: [id])
  targetStorageLocation RawMaterialStorageLocation @relation(fields: [targetStorageLocationId], references: [id])
  weighings             RawMaterialWeighing[]
  batches               RawMaterialBatch[]

  @@unique([businessId, referenceNumber])
  @@index([businessId])
  @@index([supplierId])
  @@index([targetStorageLocationId])
  @@index([qualityStatus])
  @@index([receivedAt])
  @@index([materialName])
}

model RawMaterialWeighing {
  id              String   @id @default(cuid())
  businessId      String
  referenceNumber String
  intakeId        String
  stationName     String
  grossKg         Float
  tareKg          Float
  netKg           Float
  operatorName    String
  measuredAt      DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  intake   RawMaterialIntake @relation(fields: [intakeId], references: [id])

  @@unique([businessId, referenceNumber])
  @@index([businessId])
  @@index([intakeId])
  @@index([stationName])
  @@index([operatorName])
  @@index([measuredAt])
  @@index([netKg])
}

model RawMaterialBatch {
  id                String                        @id @default(cuid())
  businessId        String
  lotCode           String
  intakeId          String
  storageLocationId String
  materialName      String
  unit              RawMaterialUnit               @default(KG)
  quantity          Float
  remainingQuantity Float
  qualityStatus     RawMaterialBatchQualityStatus @default(INSPECTION)
  expiryDate        DateTime?
  isActive          Boolean                       @default(true)
  notes             String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  business        Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  intake          RawMaterialIntake          @relation(fields: [intakeId], references: [id])
  storageLocation RawMaterialStorageLocation @relation(fields: [storageLocationId], references: [id])
  processingRuns  RawMaterialProcessingRun[]
  kandangPens     RawMaterialKandangPen[]
  stockMovements  RawMaterialStockMovement[]

  @@unique([businessId, lotCode])
  @@index([businessId])
  @@index([intakeId])
  @@index([storageLocationId])
  @@index([qualityStatus])
  @@index([expiryDate])
  @@index([isActive])
  @@index([materialName])
}

model RawMaterialProcessingRun {
  id                String                      @id @default(cuid())
  businessId        String
  runNumber         String
  inputBatchId      String
  outputName        String
  inputQuantity     Float
  outputQuantity    Float                       @default(0)
  byproductQuantity Float                       @default(0)
  wasteQuantity     Float                       @default(0)
  status            RawMaterialProcessingStatus @default(PLANNED)
  startedAt         DateTime?
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inputBatch RawMaterialBatch @relation(fields: [inputBatchId], references: [id])

  @@unique([businessId, runNumber])
  @@index([businessId])
  @@index([inputBatchId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@index([outputName])
}

model RawMaterialKandangPen {
  id           String                         @id @default(cuid())
  businessId   String
  code         String
  flockName    String
  capacity     Int                            @default(0)
  occupancy    Int                            @default(0)
  feedBatchId  String?
  healthStatus RawMaterialKandangHealthStatus @default(STABLE)
  isActive     Boolean                        @default(true)
  notes        String?
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt

  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  feedBatch RawMaterialBatch? @relation(fields: [feedBatchId], references: [id])

  @@unique([businessId, code])
  @@index([businessId])
  @@index([feedBatchId])
  @@index([healthStatus])
  @@index([isActive])
  @@index([flockName])
}

model RawMaterialStockMovement {
  id                      String                         @id @default(cuid())
  businessId              String
  batchId                 String
  sourceStorageLocationId String?
  targetStorageLocationId String?
  type                    RawMaterialStockMovementType
  reason                  RawMaterialStockMovementReason @default(MANUAL_ADJUSTMENT)
  source                  RawMaterialStockMovementSource @default(MANUAL)
  sourceId                String?
  quantity                Float
  beforeQuantity          Float
  afterQuantity           Float
  note                    String?
  createdById             String?
  createdAt               DateTime                       @default(now())

  business              Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  batch                 RawMaterialBatch            @relation(fields: [batchId], references: [id])
  sourceStorageLocation RawMaterialStorageLocation? @relation("RawMaterialStockMovementSourceStorage", fields: [sourceStorageLocationId], references: [id])
  targetStorageLocation RawMaterialStorageLocation? @relation("RawMaterialStockMovementTargetStorage", fields: [targetStorageLocationId], references: [id])
  createdBy             User?                       @relation("RawMaterialStockMovementActor", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([batchId])
  @@index([sourceStorageLocationId])
  @@index([targetStorageLocationId])
  @@index([type])
  @@index([reason])
  @@index([source])
  @@index([sourceId])
  @@index([createdAt])
  @@index([businessId, type])
  @@index([businessId, reason])
  @@index([businessId, source])
  @@index([source, sourceId])
}

model StockMovement {
  id              String               @id @default(cuid())
  inventoryItemId String
  businessId      String
  /// Legacy compatibility while old restaurant-scoped services migrate to businessId.
  restaurantId    String?
  type            StockMovementType
  quantity        Float
  reason          StockMovementReason  @default(MANUAL_ADJUSTMENT)
  source          StockMovementSource  @default(MANUAL)
  /// Legacy alias for source used by old services.
  sourceType      StockMovementSource?
  sourceId        String?
  note            String?
  createdById     String?
  /// Legacy alias for createdById used by old services.
  actorId         String?
  /// Stock level immediately before this movement was applied.
  previousStock   Float?
  /// Stock level immediately after this movement was applied.
  newStock        Float?
  /// Unit cost captured at movement time for historical COGS reporting.
  /// Null for movements that predate cost-snapshot tracking or were created
  /// without a cost context. Use InventoryItem.costPerUnit as a fallback
  /// estimate only — label it as an estimate in any UI or report.
  unitCostSnapshot  Decimal?
  /// Total cost at movement time: ABS(quantity) * unitCostSnapshot.
  /// Stored for efficiency so reports do not need to recalculate.
  totalCostSnapshot Decimal?
  createdAt       DateTime             @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  business      Business      @relation("BusinessStockMovements", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy     User?         @relation("StockMovementActor", fields: [createdById], references: [id])

  @@index([inventoryItemId])
  @@index([businessId])
  @@index([restaurantId])
  @@index([type])
  @@index([reason])
  @@index([source])
  @@index([sourceType])
  @@index([actorId])
  @@index([createdAt])
  @@index([businessId, type])
  @@index([businessId, reason])
  @@index([businessId, source])
  @@index([source, sourceId])
  @@index([unitCostSnapshot])
}

model ServiceRequest {
  id              String                        @id
  businessId      String                        @map("business_id")
  requestCode     String                        @map("request_code")
  customerName    String                        @map("customer_name")
  customerSegment String                        @default("General Service") @map("customer_segment")
  serviceCategory String                        @map("service_category")
  title           String
  summary         String?
  status          ServiceBusinessWorkflowStatus @default(REQUEST_INTAKE)
  priority        ServiceBusinessPriority       @default(NORMAL)
  dueDate         DateTime?                     @map("due_date")
  assignedTo      String?                       @map("assigned_to")
  createdAt       DateTime                      @default(now()) @map("created_at")
  updatedAt       DateTime                      @updatedAt @map("updated_at")

  business  Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  jobs      ServiceJob[]
  quotes    ServiceQuotation[]
  invoices  ServiceInvoice[]
  timeline  ServiceTimelineItem[]

  @@unique([businessId, requestCode])
  @@index([businessId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
  @@map("service_requests")
}

model ServiceJob {
  id          String                        @id
  requestId   String                        @map("request_id")
  title       String
  assignedTo  String?                       @map("assigned_to")
  status      ServiceBusinessWorkflowStatus @default(REQUEST_INTAKE)
  startedAt   DateTime?                     @map("started_at")
  completedAt DateTime?                     @map("completed_at")
  createdAt   DateTime                      @default(now()) @map("created_at")
  updatedAt   DateTime                      @updatedAt @map("updated_at")

  request        ServiceRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  costLines      ServiceCostLine[]
  quotes         ServiceQuotation[]
  checklistItems ServiceChecklistItem[]

  @@index([requestId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("service_jobs")
}

model ServiceCostLine {
  id        String                      @id
  jobId     String                      @map("job_id")
  label     String
  category  ServiceBusinessCostCategory
  quantity  Float                       @default(1)
  unitLabel String                      @default("unit") @map("unit_label")
  unitCost  Int                         @default(0) @map("unit_cost")
  billable  Boolean                     @default(true)
  createdAt DateTime                    @default(now()) @map("created_at")
  updatedAt DateTime                    @updatedAt @map("updated_at")

  job ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([category])
  @@index([billable])
  @@map("service_cost_lines")
}

model ServiceQuotation {
  id             String                     @id
  requestId      String                     @map("request_id")
  jobId          String?                    @map("job_id")
  quotationCode  String                     @map("quotation_code")
  status         ServiceBusinessQuoteStatus @default(DRAFT)
  subtotal       Int                        @default(0)
  discountAmount Int                        @default(0) @map("discount_amount")
  taxRate        Float                      @default(0) @map("tax_rate")
  taxAmount      Int                        @default(0) @map("tax_amount")
  marginRate     Float                      @default(0) @map("margin_rate")
  total          Int                        @default(0)
  validUntil     DateTime?                  @map("valid_until")
  approvedAt     DateTime?                  @map("approved_at")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  request ServiceRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  job     ServiceJob?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoices ServiceInvoice[]

  @@unique([requestId, quotationCode])
  @@index([requestId])
  @@index([jobId])
  @@index([status])
  @@index([validUntil])
  @@map("service_quotations")
}

model ServiceInvoice {
  id          String                       @id
  requestId   String                       @map("request_id")
  quotationId String?                      @map("quotation_id")
  invoiceCode String                       @map("invoice_code")
  status      ServiceBusinessInvoiceStatus @default(DRAFT)
  total       Int                          @default(0)
  paidAmount  Int                          @default(0) @map("paid_amount")
  dueDate     DateTime?                    @map("due_date")
  issuedAt    DateTime?                    @map("issued_at")
  paidAt      DateTime?                    @map("paid_at")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  request   ServiceRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quotation ServiceQuotation?  @relation(fields: [quotationId], references: [id], onDelete: SetNull)

  @@unique([requestId, invoiceCode])
  @@index([requestId])
  @@index([quotationId])
  @@index([status])
  @@index([dueDate])
  @@map("service_invoices")
}

model ServiceChecklistItem {
  id          String    @id
  jobId       String    @map("job_id")
  label       String
  isDone      Boolean   @default(false) @map("is_done")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  job ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([isDone])
  @@map("service_checklist_items")
}

model ServiceTimelineItem {
  id          String   @id
  requestId   String   @map("request_id")
  label       String
  actorName   String   @default("System") @map("actor_name")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([occurredAt])
  @@map("service_timeline_items")
}

model CashflowEntry {
  id          String              @id @default(cuid())
  businessId  String
  type        CashflowEntryType
  account     CashflowAccount     @default(CASH)
  amount      Int
  status      CashflowEntryStatus @default(POSTED)
  occurredAt  DateTime            @default(now())
  title       String
  description String?
  sourceType  CashflowSourceType  @default(MANUAL)
  sourceId    String?
  reference   String?
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  business  Business @relation("BusinessCashflowEntries", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("CashflowEntryCreator", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([type])
  @@index([status])
  @@index([occurredAt])
  @@index([sourceType])
  @@index([sourceId])
  @@index([businessId, type])
  @@index([businessId, status])
  @@index([businessId, sourceType])
  @@index([businessId, account])
  @@index([sourceType, sourceId])
  @@index([createdById])
}

model DiningTable {
  id         String      @id @default(cuid())
  name       String
  capacity   Int         @default(2)
  status     TableStatus @default(AVAILABLE)
  isActive   Boolean     @default(true)
  businessId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([businessId])
  @@index([status])
  @@index([isActive])
}

model Shift {
  id             String      @id @default(cuid())
  userId         String
  businessId     String
  status         ShiftStatus @default(OPEN)
  openingCash    Int         @default(0)
  closingCash    Int?
  expectedCash   Int         @default(0)
  cashDifference Int?
  openedAt       DateTime    @default(now())
  closedAt       DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  orders   Order[]

  @@index([businessId])
  @@index([status])
  @@index([openedAt])
}

model Attendance {
  id                  String           @id @default(cuid())
  userId              String
  businessId          String
  clockInAt           DateTime
  clockOutAt          DateTime?
  workDurationMinutes Int              @default(0)
  overtimeMinutes     Int              @default(0)
  note                String?
  status              AttendanceStatus @default(PRESENT)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessId])
  @@index([status])
}

model AttendanceSetting {
  id                   String   @id @default(cuid())
  businessId           String   @unique
  workStartHour        Int      @default(9)
  workStartMinute      Int      @default(0)
  lateTolerance        Int      @default(15)
  overtimeAfterMinutes Int      @default(480)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId], name: "role_permissionId")
  @@index([permissionId])
}

model AuditLog {
  id           String      @id @default(cuid())
  businessId   String
  /// Legacy compatibility while old restaurant-scoped services migrate to businessId.
  restaurantId String?
  userId       String
  action       AuditAction
  entityType   String
  entityId     String
  changes      Json?
  createdAt    DateTime    @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([restaurantId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model HppBatch {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  batchDate    DateTime
  outputUnits  Int
  targetMargin Float    @default(0.65)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  components HppCostComponent[]

  @@index([businessId])
  @@index([batchDate])
}

model HppCostComponent {
  id        String   @id @default(cuid())
  batchId   String
  name      String
  category  String
  unitCost  Int
  quantity  Float
  unit      String
  totalCost Int
  note      String?
  createdAt DateTime @default(now())

  batch HppBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

