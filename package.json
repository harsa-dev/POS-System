{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "business-mode:check": "node ./scripts/business-mode-switch-check.mjs",
    "business-mode:browser-smoke": "node ./scripts/business-mode-browser-smoke.mjs",
    "business-mode:e2e": "node ./scripts/business-mode-e2e.mjs",
    "platform-admin:check": "node ./scripts/platform-admin-internal-monitoring-check.mjs && node ./scripts/platform-admin-policy-parity-check.mjs && node ./scripts/platform-admin-contract-parity-check.mjs && node ./scripts/platform-admin-final-qa-check.mjs",
    "platform-admin:policy-parity": "node ./scripts/platform-admin-policy-parity-check.mjs",
    "platform-admin:contract-parity": "node ./scripts/platform-admin-contract-parity-check.mjs",
    "platform-admin:final-qa": "node ./scripts/platform-admin-final-qa-check.mjs",
    "platform-admin:browser-smoke": "node ./scripts/platform-admin-internal-monitoring-browser-smoke.mjs",
    "restaurant:baseline": "pnpm --filter @workspace/api-server run restaurant:baseline:check",
    "restaurant:check": "node ./scripts/restaurant-check.mjs",
    "restaurant:smoke": "node ./scripts/restaurant-api-smoke.mjs",
    "retail:check": "node ./scripts/retail-check.mjs",
    "retail:smoke": "node ./scripts/retail-api-smoke.mjs",
    "raw-material:check": "node ./scripts/raw-material-check.mjs",
    "raw-material:smoke": "node ./scripts/raw-material-api-smoke.mjs",
    "service:check": "node ./scripts/service-check.mjs",
    "service:smoke": "node ./scripts/service-api-smoke.mjs"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "@rollup/rollup-win32-x64-msvc": "^4.60.3",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/vite": "4.3.0",
    "autoprefixer": "^10.5.15",
    "esbuild": "0.27.3",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "tw-animate-css": "^1.4.0"
  }
}
